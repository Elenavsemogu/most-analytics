# TGStat API (https://tgstat.ru/my/profile -> API)
TGSTAT_TOKEN=your_tgstat_token_here

# Username канала MOST (например @mostjobs или t.me/mostjobs)
MOST_CHANNEL_ID=@your_channel_username

# OpenAI API (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your_openai_key_here

# Пароль для входа на дашборд (если пустой — доступ без пароля)
DASHBOARD_PASSWORD=
